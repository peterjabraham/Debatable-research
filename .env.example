ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used by the topic refiner (GPT-4.1)
OPENAI_API_KEY=sk-...

# Railway backend URL (used by the UI and for CORS)
# Set this to your Railway deployment URL once deployed
# e.g. https://debatable-research-production.up.railway.app
RAILWAY_API_URL=

# CORS — comma-separated origins allowed to call the API
# Add your Cloudflare Pages URL once deployed
# e.g. https://debatable-research.pages.dev,http://localhost
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Optional pipeline overrides
PIPELINE_LOG_LEVEL=INFO
PIPELINE_MAX_TOTAL_TOKENS=150000
